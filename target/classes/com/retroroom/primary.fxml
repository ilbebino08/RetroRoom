<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.text.Font?>

<StackPane fx:id="rootPane" prefHeight="720.0" prefWidth="1280.0" style="-fx-background-color: #1a1a1a;" xmlns="http://javafx.com/javafx/11.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.retroroom.PrimaryController">
    <stylesheets>
        <URL value="@style.css" />
    </stylesheets>

    <BorderPane>
        <left>
            <VBox alignment="TOP_CENTER" prefWidth="300.0" spacing="10.0" styleClass="steampunk-panel" BorderPane.alignment="CENTER">
                <children>
                    <Label styleClass="leaderboard-title" text="DUNGEON MASTER" textAlignment="CENTER" wrapText="true" />
                    <Label text="LEADERBOARD" textFill="#cd7f32">
                        <font>
                            <Font name="System Bold" size="18.0" />
                        </font>
                    </Label>
                    <ListView fx:id="dungeonLeaderboard" prefHeight="500.0" prefWidth="280.0" styleClass="leaderboard-list" />
                </children>
                <padding>
                    <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                </padding>
                <BorderPane.margin>
                    <Insets bottom="20.0" left="20.0" top="20.0" />
                </BorderPane.margin>
            </VBox>
        </left>

        <right>
            <VBox alignment="TOP_CENTER" prefWidth="300.0" spacing="10.0" styleClass="steampunk-panel" BorderPane.alignment="CENTER">
                <children>
                    <Label styleClass="leaderboard-title" text="SPACE INVADERS" textAlignment="CENTER" wrapText="true" />
                    <Label text="LEADERBOARD" textFill="#cd7f32">
                        <font>
                            <Font name="System Bold" size="18.0" />
                        </font>
                    </Label>
                    <ListView fx:id="spaceLeaderboard" prefHeight="500.0" prefWidth="280.0" styleClass="leaderboard-list" />
                </children>
                <padding>
                    <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                </padding>
                <BorderPane.margin>
                    <Insets bottom="20.0" right="20.0" top="20.0" />
                </BorderPane.margin>
            </VBox>
        </right>

        <center>
            <VBox alignment="CENTER" spacing="0.0" BorderPane.alignment="CENTER">
                <children>
                    <!-- Arcade Cabinet Top -->
                    <StackPane>
                        <children>
                             <Label text="RETRO ROOM" textFill="#ffd700" style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.8), 10, 0, 0, 0);" translateY="-30" />
                        </children>
                    </StackPane>

                    <!-- Main Cabinet Body -->
                    <VBox alignment="CENTER" styleClass="arcade-cabinet" VBox.vgrow="ALWAYS">
                         <!-- Screen Area -->
                         <StackPane styleClass="screen-border" VBox.vgrow="ALWAYS">
                             <StackPane fx:id="gameScreen" styleClass="game-screen" prefWidth="600" prefHeight="400">
                                 <children>
                                      <!-- Default screen content: Game Menu -->
                                      <VBox alignment="CENTER" spacing="20">
                                          <Label text="SELECT GAME" textFill="#00ff00" style="-fx-font-size: 24px; -fx-font-family: 'Monospaced';" />
                                          <HBox alignment="CENTER" spacing="30">
                                              <Button text="Dungeon Master" styleClass="arcade-button" style="-fx-background-radius: 10; -fx-min-width: 150; -fx-min-height: 40; -fx-background-color: #4e342e; -fx-text-fill: white;" />
                                              <Button text="Space Invaders" styleClass="arcade-button" style="-fx-background-radius: 10; -fx-min-width: 150; -fx-min-height: 40; -fx-background-color: #4e342e; -fx-text-fill: white;" />
                                          </HBox>
                                      </VBox>
                                 </children>
                             </StackPane>
                         </StackPane>

                         <!-- Control Panel -->
                         <HBox alignment="CENTER" spacing="50.0" styleClass="control-panel">
                             <padding>
                                 <Insets top="20" bottom="20" />
                             </padding>

                             <!-- Joystick Left -->
                             <StackPane styleClass="joystick-base">
                                 <Circle radius="20.0" styleClass="joystick-stick" />
                             </StackPane>

                             <!-- Buttons Center -->
                             <HBox spacing="15.0">
                                 <Button styleClass="arcade-button" />
                                 <Button styleClass="arcade-button" style="-fx-background-color: radial-gradient(center 50% 50%, radius 50%, #2196f3, #0d47a1);" />
                                 <Button styleClass="arcade-button" style="-fx-background-color: radial-gradient(center 50% 50%, radius 50%, #4caf50, #1b5e20);" />
                             </HBox>

                              <!-- Joystick Right (Optional for 2 players or symmetry) -->
                             <StackPane styleClass="joystick-base">
                                 <Circle radius="20.0" styleClass="joystick-stick" />
                             </StackPane>

                         </HBox>
                    </VBox>
                </children>
                <BorderPane.margin>
                    <Insets bottom="20.0" left="10.0" right="10.0" top="20.0" />
                </BorderPane.margin>
            </VBox>
        </center>
    </BorderPane>
</StackPane>
